# ─────────────────────────────────────────────────────────────
# BookWise Backend — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────

# CORS: comma-separated list of allowed frontend origins
# Supports * wildcard, e.g. https://bookwise-git-*.vercel.app
FRONTEND_URL=http://localhost:4200

# ── Supabase ─────────────────────────────────────────────────
# URL of your Supabase project (found in Project Settings → API)
SUPABASE_URL=https://<project-ref>.supabase.co

# Service role key — bypasses RLS; keep absolutely secret
# Found in Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Encryption ───────────────────────────────────────────────
# Fernet symmetric key used to encrypt user API keys at rest.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotate this key only in a coordinated way: all stored keys must be re-encrypted,
# or users will need to re-enter their Gemini API key.
API_KEY_ENCRYPTION_SECRET=your_fernet_key_here

# ── Deprecated ───────────────────────────────────────────────
# GEMINI_API_KEY is no longer used. Each user provides their own key via the UI.
# GEMINI_API_KEY=removed
