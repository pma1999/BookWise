# ─────────────────────────────────────────────────────────────
# BookWise Backend — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────

# CORS: comma-separated list of allowed frontend origins.
# Supports * wildcard, e.g. https://bookwise-git-*.vercel.app
FRONTEND_URL=http://localhost:4200

# ── Deprecated / not used ────────────────────────────────────
# GEMINI_API_KEY is NOT used. Each user provides their own key
# via the UI. The backend reads it from the X-Gemini-Api-Key header.
# GEMINI_API_KEY=removed
